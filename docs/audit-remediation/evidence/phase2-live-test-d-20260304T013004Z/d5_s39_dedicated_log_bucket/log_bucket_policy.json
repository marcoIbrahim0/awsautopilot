{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3ServerAccessLogsAclCheck",
      "Effect": "Allow",
      "Principal": {"Service": "logging.s3.amazonaws.com"},
      "Action": "s3:GetBucketAcl",
      "Resource": "arn:aws:s3:::sa-live-d5-log-029037611564-0304014445",
      "Condition": {
        "StringEquals": {"aws:SourceAccount": "029037611564"},
        "ArnLike": {"aws:SourceArn": "arn:aws:s3:::sa-live-d5-src-029037611564-0304014445"}
      }
    },
    {
      "Sid": "S3ServerAccessLogsWrite",
      "Effect": "Allow",
      "Principal": {"Service": "logging.s3.amazonaws.com"},
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::sa-live-d5-log-029037611564-0304014445/*",
      "Condition": {
        "StringEquals": {
          "aws:SourceAccount": "029037611564",
          "s3:x-amz-acl": "bucket-owner-full-control"
        },
        "ArnLike": {"aws:SourceArn": "arn:aws:s3:::sa-live-d5-src-029037611564-0304014445"}
      }
    }
  ]
}
