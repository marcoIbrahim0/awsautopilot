":"AwsAccount","control_id":"S3.9","standard_name":"standards/aws-foundational-security-best-practices/v/1.0.0","first_observed_at":"2026-03-11T18:46:05.367000+00:00","last_observed_at":"2026-03-20T13:09:34.644000+00:00","resolved_at":"2026-03-20T13:09:34.644000+00:00","updated_at":"2026-03-20T13:09:34.644000+00:00","created_at":"2026-03-12T15:32:55.862376+00:00","updated_at_db":"2026-03-20T17:36:30.417478+00:00","raw_json":null,"shadow":null,"exception_id":null,"exception_expires_at":null,"exception_expired":null,"remediation_action_id":null,"remediation_action_type":null,"remediation_action_status":null,"remediation_action_account_id":null,"remediation_action_region":null,"remediation_action_group_id":null,"remediation_action_group_status_bucket":null,"remediation_action_group_latest_run_status":null,"latest_pr_bundle_run_id":null,"pending_confirmation":false,"pending_confirmation_started_at":null,"pending_confirmation_deadline_at":null,"pending_confirmation_message":null,"pending_confirmation_severity":null},{"id":"2cc7100f-0f7a-4263-9337-e95836a1dfb9","finding_id":"arn:aws:securityhub:us-east-1:696505809372:security-control/S3.8/finding/51d3f821-3843-4088-9ead-40e1621ac8b5","tenant_id":"9f7616d8-af04-43ca-99cd-713625357b70","account_id":"696505809372","region":"us-east-1","source":"security_hub","severity_label":"INFORMATIONAL","severity_normalized":0,"canonical_status":"RESOLVED","status":"RESOLVED","effective_status":"RESOLVED","display_badge":"resolved","in_scope":true,"is_shared_resource":false,"title":"S3 general purpose buckets should block public access","description":"This control checks whether an Amazon S3 general purpose bucket blocks public access at the bucket level. The control fails if any of the following settings are set to false: ignorePublicAcls, blockPublicPolicy, blockPublicAcls, restrictPublicBuckets.","resource_id":"AWS::::Account:696505809372","resource_type":"AwsAccount","control_id":"S3.8","standard_name":"standards/aws-foundational-security-best-practices/v/1.0.0","first_observed_at":"2026-03-11T18:46:05.187000+00:00","last_observed_at":"2026-03-20T13:09:34.505000+00:00","resolved_at":"2026-03-20T13:09:34.505000+00:00","updated_at":"2026-03-20T13:09:34.505000+00:00","created_at":"2026-03-12T15:32:55.862376+00:00","updated_at_db":"2026-03-20T17:36:30.417478+00:00","raw_json":null,"shadow":null,"exception_id":null,"exception_expires_at":null,"exception_expired":null,"remediation_action_id":null,"remediation_action_type":null,"remediation_action_status":null,"remediation_action_account_id":null,"remediation_action_region":null,"remediation_action_group_id":null,"remediation_action_group_status_bucket":null,"remediation_action_group_latest_run_status":null,"latest_pr_bundle_run_id":null,"pending_confirmation":false,"pending_confirmation_started_at":null,"pending_confirmation_deadline_at":null,"pending_confirmation_message":null,"pending_confirmation_severity":null},{"id":"c1d4ec45-9152-4324-ae6c-5b353839f7da","finding_id":"arn:aws:securityhub:us-east-1:696505809372:security-control/S3.5/finding/0e59cff1-1902-4060-a1a9-ace8292ce2a4","tenant_id":"9f7616d8-af04-43ca-99cd-713625357b70","account_id":"696505809372","region":"us-east-1","source":"security_hub","severity_label":"INFORMATIONAL","severity_normalized":0,"canonical_status":"RESOLVED","status":"RESOLVED","effective_status":"RESOLVED","display_badge":"resolved","in_scope":true,"is_shared_resource":false,"title":"S3 general purpose buckets should require requests to use SSL","description":"This control checks whether an Amazon S3 general purpose bucket has a policy that requires requests to use SSL. The control fails if the bucket policy doesn't require requests to use SSL.","resource_id":"AWS::::Account:696505809372","resource_type":"AwsAccount","control_id":"S3.5","standard_name":"standards/aws-foundational-security-best-practices/v/1.0.0","first_observed_at":"2026-03-11T18:46:04.858000+00:00","last_observed_at":"2026-03-20T13:09:34.304000+00:00"