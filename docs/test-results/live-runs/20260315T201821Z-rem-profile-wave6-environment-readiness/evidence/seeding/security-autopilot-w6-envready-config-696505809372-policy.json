{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowImportRoleBucketReadinessChecks",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::696505809372:role/CodexP2SecurityHubImportRole"
      },
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketAcl",
        "s3:GetBucketLocation",
        "s3:GetBucketLogging",
        "s3:GetBucketPolicy",
        "s3:GetBucketPolicyStatus",
        "s3:GetBucketWebsite",
        "s3:GetLifecycleConfiguration",
        "s3:GetEncryptionConfiguration"
      ],
      "Resource": "arn:aws:s3:::security-autopilot-w6-envready-config-696505809372"
    },
    {
      "Sid": "AWSConfigBucketPermissionsCheck",
      "Effect": "Allow",
      "Principal": {
        "Service": "config.amazonaws.com"
      },
      "Action": "s3:GetBucketAcl",
      "Resource": "arn:aws:s3:::security-autopilot-w6-envready-config-696505809372"
    },
    {
      "Sid": "AWSConfigBucketDelivery",
      "Effect": "Allow",
      "Principal": {
        "Service": "config.amazonaws.com"
      },
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::security-autopilot-w6-envready-config-696505809372/AWSLogs/696505809372/Config/*",
      "Condition": {
        "StringEquals": {
          "s3:x-amz-acl": "bucket-owner-full-control"
        }
      }
    }
  ]
}
