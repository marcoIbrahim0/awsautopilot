{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowAssumeFromSaaSExecutionRolesWithExternalId",
            "Effect": "Allow",
            "Principal": {
                "AWS": [
                    "arn:aws:iam::029037611564:role/security-autopilot-dev-lambda-api",
                    "arn:aws:iam::029037611564:role/security-autopilot-dev-lambda-worker"
                ]
            },
            "Action": "sts:AssumeRole",
            "Condition": {
                "StringEquals": {
                    "sts:ExternalId": "ext-1f274864a7704551"
                }
            }
        },
        {
            "Sid": "AllowSessionAuditContextFromSaaSExecutionRoles",
            "Effect": "Allow",
            "Principal": {
                "AWS": [
                    "arn:aws:iam::029037611564:role/security-autopilot-dev-lambda-api",
                    "arn:aws:iam::029037611564:role/security-autopilot-dev-lambda-worker"
                ]
            },
            "Action": [
                "sts:SetSourceIdentity",
                "sts:TagSession"
            ]
        }
    ]
}
