    "Policy": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Sid\":\"AWSConfigBucketPermissionsCheck\",\"Effect\":\"Allow\",\"Principal\":{\"Service\":\"config.amazonaws.com\"},\"Action\":\"s3:GetBucketAcl\",\"Resource\":\"arn:aws:s3:::security-autopilot-config-696505809372-eu-north-1\",\"Condition\":{\"StringEquals\":{\"AWS:SourceAccount\":\"696505809372\"}}},{\"Sid\":\"AWSConfigBucketExistenceCheck\",\"Effect\":\"Allow\",\"Principal\":{\"Service\":\"config.amazonaws.com\"},\"Action\":\"s3:ListBucket\",\"Resource\":\"arn:aws:s3:::security-autopilot-config-696505809372-eu-north-1\",\"Condition\":{\"StringEquals\":{\"AWS:SourceAccount\":\"696505809372\"}}},{\"Sid\":\"AWSConfigBucketDelivery\",\"Effect\":\"Allow\",\"Principal\":{\"Service\":\"config.amazonaws.com\"},\"Action\":\"s3:PutObject\",\"Resource\":\"arn:aws:s3:::security-autopilot-config-696505809372-eu-north-1/AWSLogs/696505809372/Config/*\",\"Condition\":{\"StringEquals\":{\"AWS:SourceAccount\":\"696505809372\",\"s3:x-amz-acl\":\"bucket-owner-full-control\"}}},{\"Sid\":\"DenyInsecureTransport\",\"Effect\":\"Deny\",\"Principal\":\"*\",\"Action\":\"s3:*\",\"Resource\":[\"arn:aws:s3:::security-autopilot-config-696505809372-eu-north-1/*\",\"arn:aws:s3:::security-autopilot-config-696505809372-eu-north-1\"],\"Condition\":{\"Bool\":{\"aws:SecureTransport\":\"false\"}}}]}"
