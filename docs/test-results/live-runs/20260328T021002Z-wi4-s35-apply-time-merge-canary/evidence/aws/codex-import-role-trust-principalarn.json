{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowAssumeFromSaaSAccountWithExternalId",
            "Effect": "Allow",
            "Principal": {
                "AWS": "arn:aws:iam::029037611564:root"
            },
            "Action": "sts:AssumeRole",
            "Condition": {
                "StringEquals": {
                    "sts:ExternalId": "ocypheris-p2-e2e-20260312"
                },
                "ArnEquals": {
                    "aws:PrincipalArn": [
                        "arn:aws:iam::029037611564:user/AutoPilotAdmin",
                        "arn:aws:iam::029037611564:role/CodexWI4LocalApiRole"
                    ]
                }
            }
        },
        {
            "Sid": "AllowSessionAuditContextFromSaaSAccount",
            "Effect": "Allow",
            "Principal": {
                "AWS": "arn:aws:iam::029037611564:root"
            },
            "Action": [
                "sts:SetSourceIdentity",
                "sts:TagSession"
            ],
            "Condition": {
                "ArnEquals": {
                    "aws:PrincipalArn": [
                        "arn:aws:iam::029037611564:user/AutoPilotAdmin",
                        "arn:aws:iam::029037611564:role/CodexWI4LocalApiRole"
                    ]
                }
            }
        }
    ]
}
