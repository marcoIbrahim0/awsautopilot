{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowCodexOperatorAssumeRole",
            "Effect": "Allow",
            "Principal": {
                "AWS": "arn:aws:iam::029037611564:user/AutoPilotAdmin"
            },
            "Action": "sts:AssumeRole",
            "Condition": {
                "StringEquals": {
                    "sts:ExternalId": "ocypheris-p2-e2e-20260312"
                }
            }
        },
        {
            "Sid": "AllowCodexOperatorSessionContext",
            "Effect": "Allow",
            "Principal": {
                "AWS": "arn:aws:iam::029037611564:user/AutoPilotAdmin"
            },
            "Action": [
                "sts:SetSourceIdentity",
                "sts:TagSession"
            ]
        }
    ]
}
