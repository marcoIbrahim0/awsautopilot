          }
        },
        "Effect": "Deny",
        "Principal": "*",
        "Resource": [
          "arn:aws:s3:::security-autopilot-config-696505809372-eu-north-1/*",
          "arn:aws:s3:::security-autopilot-config-696505809372-eu-north-1"
        ],
        "Sid": "DenyInsecureTransport"
      }
    ],
    "Version": "2012-10-17"
  },
  "version": 1
}
