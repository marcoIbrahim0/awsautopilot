ROLE_SESSION_NAME="security-autopilot-session"

# Queues (legacy + phase 1/2)
SQS_INGEST_QUEUE_URL="https://sqs.eu-north-1.amazonaws.com/029037611564/security-autopilot-ingest-queue"
SQS_INGEST_DLQ_URL="https://sqs.eu-north-1.amazonaws.com/029037611564/security-autopilot-ingest-dlq"

SQS_EVENTS_FAST_LANE_QUEUE_URL="https://sqs.eu-north-1.amazonaws.com/029037611564/security-autopilot-events-fastlane-queue"
SQS_EVENTS_FAST_LANE_DLQ_URL="https://sqs.eu-north-1.amazonaws.com/029037611564/security-autopilot-events-fastlane-dlq"

SQS_INVENTORY_RECONCILE_QUEUE_URL="https://sqs.eu-north-1.amazonaws.com/029037611564/security-autopilot-inventory-reconcile-queue"
SQS_INVENTORY_RECONCILE_DLQ_URL="https://sqs.eu-north-1.amazonaws.com/029037611564/security-autopilot-inventory-reconcile-dlq"

# Control-plane behavior
CONTROL_PLANE_SHADOW_MODE="true"
CONTROL_PLANE_AUTHORITATIVE_CONTROLS="S3.1,SecurityHub.1,GuardDuty.1,S3.2,S3.4,EC2.53,CloudTrail.1,Config.1,SSM.7,EC2.182,EC2.7,S3.5,IAM.4,S3.9,S3.11,S3.15"

CONTROL_PLANE_SOURCE="event_monitor_shadow"
CONTROL_PLANE_RECENT_TOUCH_LOOKBACK_MINUTES="60"

# Worker queue pool selector: legacy | events | inventory | all
WORKER_POOL="all"
SAAS_SERVERLESS_ENABLE_WORKER="true"
SAAS_SERVERLESS_WORKER_RESERVED_CONCURRENCY="10"

# Public backend URL (used for CloudFormation param prefill; AWS cannot call localhost)
API_PUBLIC_URL="https://api.ocypheris.com"
FIREBASE_PROJECT_ID="aws-security-autopilot"
FIREBASE_EMAIL_CONTINUE_URL_BASE="https://ocypheris.com"
EMAIL_FROM="noreply@ocypheris.com"
EMAIL_SMTP_HOST="email-smtp.eu-north-1.amazonaws.com"
EMAIL_SMTP_PORT="587"
EMAIL_SMTP_STARTTLS="true"
EMAIL_SMTP_CREDENTIALS_SECRET_ID="security-autopilot-dev/EMAIL_SMTP"
OPENAI_HELP_ENABLED="true"
OPENAI_API_KEY_SECRET_ID="security-autopilot-dev/OPENAI_API_KEY"
OPENAI_HELP_MODEL="gpt-4.1-mini"
OPENAI_HELP_REASONING_EFFORT="low"
OPENAI_HELP_TIMEOUT_SECONDS="30"

# CloudFormation (Phase 1 forwarder)
CLOUDFORMATION_CONTROL_PLANE_FORWARDER_TEMPLATE_URL="https://security-autopilot-templates.s3.eu-north-1.amazonaws.com/cloudformation/control-plane-forwarder/v1.0.0.yaml"

# Storage/support/admin
S3_EXPORT_BUCKET="security-autopilot-exports"
S3_EXPORT_BUCKET_REGION="eu-north-1"
S3_SUPPORT_BUCKET="autopilot-s3-support-bucket"
S3_SUPPORT_BUCKET_REGION="eu-north-1"
SAAS_ADMIN_EMAILS="marcoibrahim11@outlook.com,Messi3amak@gmail.com"

# SaaS bundle executor
SAAS_BUNDLE_EXECUTOR_ENABLED="true"
SAAS_BUNDLE_RUNNER_TEMPLATE_S3_URI="s3://autopilot-prbundle-run/run_all.sh"
SAAS_BUNDLE_RUNNER_TEMPLATE_VERSION="v1.6.7"

# Frontend flags (Next.js reads these via frontend dev script)
NEXT_PUBLIC_CONTROL_PLANE_RECONCILE_UI_ENABLED="true"

